# Cloudflare Pages HTTP headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # CSP en modo Report-Only: VIGILA pero NO bloquea nada (cero riesgo de romper el
  # sitio en vivo). Si tras unos días no hay violaciones legítimas en la consola,
  # se puede pasar a 'Content-Security-Policy' (enforce).
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://images.unsplash.com; font-src 'self' https://fonts.gstatic.com; frame-src https://www.google.com; connect-src 'self'; object-src 'none'; base-uri 'self'

# Cached images: filenames are not content-hashed, so allow daily revalidation
/*.webp
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/*.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/*.webmanifest
  Cache-Control: public, max-age=86400
